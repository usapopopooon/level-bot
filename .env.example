# =============================================================================
# Discord bot
# =============================================================================

# Discord Bot Token (required for bot process; API のみ起動なら空でも可)
# Get from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# =============================================================================
# Database
# =============================================================================

# DB URL (required for production)
# Local:   postgresql+asyncpg://user:password@localhost:5432/level_bot
# Railway: Postgres plugin が自動で設定 (postgres:// 形式 → engine 側で変換)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/level_bot

# DB 接続オプション
DATABASE_REQUIRE_SSL=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# =============================================================================
# Runtime
# =============================================================================

# ローカル日時境界 (UTC からのオフセット時間)
TIMEZONE_OFFSET=9

# ログレベル (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# API サーバーが listen するポート。Railway は自動でセット (uvicorn が読む)
PORT=8000

# 起動時に必須 env の検証を有効化するフラグ (production / staging / dev)。
# "production" のとき SESSION_SECRET_KEY / ADMIN_PASSWORD / CORS_ORIGINS が
# 空だと起動を拒否する。Railway は RAILWAY_ENVIRONMENT_NAME を自動で渡す。
ENVIRONMENT=dev

# Bot 自身が自分の URL を必要とする時の表示用 (フロントエンドへの誘導等)
APP_URL=http://localhost:8000

# ダッシュボードを公開扱いにするか (フラグ; 現状参照箇所限定)
PUBLIC_DASHBOARD=true

# =============================================================================
# CORS
# =============================================================================

# API を叩ける origin の comma-separated 列挙。
# allow_credentials=True と "*" は併用不可なので必ず明示する。
# Vite dev server (../chill-cafe-site) は通常 http://localhost:5173。
# 本番では Next.js の公開 URL を入れる。
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Web auth — single admin login (JWT in httpOnly cookie)
# =============================================================================

# 管理画面ログインの資格情報。ADMIN_PASSWORD が空のときはログイン常時 401。
ADMIN_USER=admin
ADMIN_PASSWORD=

# JWT 署名鍵。空のままだと起動毎に乱数 = 再起動で全セッション失効。
# 本番では 32 バイト以上の固定値を必ず設定する (例: openssl rand -hex 32)
SESSION_SECRET_KEY=

# HTTPS 環境では true。ローカル開発は false でも動く。
SECURE_COOKIE=false

# =============================================================================
# External API key (server-to-server, GET only)
# =============================================================================

# 別 Railway プロジェクト等から `Authorization: Bearer <key>` で叩く用。
# 空なら外部 API は完全無効 (どんな Bearer ヘッダも 401)。
# 本番では `openssl rand -hex 32` で生成した値を双方の env に置く。
EXTERNAL_API_KEY=

# =============================================================================
# User stats site link shown by /level
# =============================================================================

# 両方設定すると、指定ギルドの /level 表示に外部ユーザー統計ページへのリンクを出す。
# 例: https://chill-cafe.site/u/{user_id}?days=30
USER_STATS_SITE_GUILD_ID=
USER_STATS_SITE_BASE_URL=

# =============================================================================
# Frontend (Next.js)
# =============================================================================

# Server Component からの直接 fetch と Next の rewrite 先で使う API URL。
# ローカル: http://localhost:8000
# 本番: level-bot API サービスの公開 URL
API_URL=http://localhost:8000
