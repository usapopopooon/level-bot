# Discord Bot Token (required)
# Get from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# Database URL (required for production)
# Local: postgresql+asyncpg://user:password@localhost:5432/level_bot
# Railway: automatically set by Postgres plugin (DATABASE_URL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/level_bot

# Bot runtime options
TIMEZONE_OFFSET=9
LOG_LEVEL=INFO

# Web dashboard
APP_URL=http://localhost:8000
PUBLIC_DASHBOARD=true

# CORS — comma-separated origins allowed to hit the API.
# In production, set this to your Next.js public URL.
# auth クッキーを使う関係で allow_credentials=True なので "*" 禁止、明示列挙する。
CORS_ORIGINS=http://localhost:3000

# Web auth — single admin login (JWT in httpOnly cookie)
# 未設定だとログインは常に 401。本番では必ず長くて推測不能な値にする。
ADMIN_USER=admin
ADMIN_PASSWORD=
# JWT 署名鍵。空のままだと起動毎に乱数 = 再起動で全セッション失効。
# 本番では 32 バイト以上の固定値を必ず設定する (例: openssl rand -hex 32)。
SESSION_SECRET_KEY=
# HTTPS 環境では true。ローカル開発は false でも動く。
SECURE_COOKIE=false

# External API key (server-to-server, GET only)
# 別 Railway プロジェクト等から `Authorization: Bearer <key>` で叩く用。
# 空のままだと外部 API は無効 (どんな Bearer ヘッダも 401)。
# 本番では `openssl rand -hex 32` 等で生成した値を双方の env に置く。
EXTERNAL_API_KEY=

# Frontend build-time API destination (used by frontend/Dockerfile and rewrites)
API_URL=http://localhost:8000

# Database connection options
DATABASE_REQUIRE_SSL=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
