# Discord Bot Token (required)
# Get from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# Database URL (required for production)
# Local: postgresql+asyncpg://user:password@localhost:5432/level_bot
# Railway: automatically set by Postgres plugin (DATABASE_URL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/level_bot

# Bot runtime options
TIMEZONE_OFFSET=9
LOG_LEVEL=INFO

# Web dashboard
APP_URL=http://localhost:8000
PUBLIC_DASHBOARD=true

# CORS — comma-separated origins allowed to hit the API.
# In production, set this to your Next.js public URL.
CORS_ORIGINS=http://localhost:3000

# Frontend build-time API destination (used by frontend/Dockerfile and rewrites)
API_URL=http://localhost:8000

# Database connection options
DATABASE_REQUIRE_SSL=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
