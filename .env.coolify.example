# Keep this false while Railway is still running the bot with the same token.
BOT_ENABLED=false

# Required only when BOT_ENABLED=true.
DISCORD_TOKEN=

# PostgreSQL in Coolify.
SERVICE_PASSWORD_POSTGRES=level-postgres-password
POSTGRES_DB=level_bot
POSTGRES_USER=level
DATABASE_REQUIRE_SSL=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Runtime.
ENVIRONMENT=production
TIMEZONE_OFFSET=9
LOG_LEVEL=INFO
APP_URL=
PUBLIC_DASHBOARD=true

# Admin dashboard auth. Set real secrets in Coolify Variables.
ADMIN_USER=admin
ADMIN_PASSWORD=
SESSION_SECRET_KEY=
SECURE_COOKIE=true

# API exposure.
CORS_ORIGINS=
EXTERNAL_API_KEY=
CHILL_API_KEY=

# User stats links shown by bot responses.
USER_STATS_SITE_BASE_URL=
USER_STATS_SITE_GUILD_ID=

# intro-bot API integration for migration dual-write.
INTRO_API_BASE_URL=
INTRO_API_KEY=

# Frontend.
NEXT_PUBLIC_JOIN_SERVER_URL=https://discord.com/invite/chill-cafe

# Resource limits.
POSTGRES_MEMORY_LIMIT=256m
POSTGRES_CPUS=0.50
BOT_MEMORY_LIMIT=384m
BOT_CPUS=0.75
API_MEMORY_LIMIT=384m
API_CPUS=0.75
FRONTEND_MEMORY_LIMIT=384m
FRONTEND_CPUS=1.00
